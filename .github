name: Build Windows EXE

on:
  workflow_dispatch:
  push:
    branches: [main]

jobs:
  build:
    runs-on: windows-latest

    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: |
          pip install openpyxl pandas python-calamine xlsxwriter pyinstaller

      - name: Build EXE
        run: |
          pyinstaller `
            --onefile `
            --name cnm_scrypt `
            --add-data "data;data" `
            --hidden-import python_calamine `
            --hidden-import openpyxl `
            --hidden-import pandas `
            --hidden-import xlsxwriter `
            __main__.py

      - name: Upload EXE
        uses: actions/upload-artifact@v4
        with:
          name: cnm_scrypt_exe
          path: dist/cnm_scrypt.exe
